  "item": [
    {
      "name": "Create Book",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201 - Created\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "pm.test(\"Response contains all required book fields\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.data).to.have.property('title');\r",
              "    pm.expect(jsonData.data).to.have.property('author');\r",
              "    pm.expect(jsonData.data).to.have.property('isbn');\r",
              "    pm.expect(jsonData.data).to.have.property('genre');\r",
              "    pm.expect(jsonData.data).to.have.property('availableCopies');\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"title\": \"Atomic Habits\",\r\n    \"author\": \"James Clear\",\r\n    \"isbn\": \"978-0735211292\",\r\n    \"genre\": \"Self-Help\",\r\n    \"availableCopies\": 12\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
